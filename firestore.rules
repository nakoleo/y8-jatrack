rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'info.nakoleo@gmail.com';
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Collection group rule — required for collectionGroup('entries') admin query
    match /{path=**}/entries/{entryId} {
      allow read: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isSuperAdmin();

      match /entries/{entryId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow create, update, delete: if isOwner(userId) || isSuperAdmin();
      }

      match /dailyReports/{reportId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow create, update, delete: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /kpiConfigs/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create, update, delete: if isOwner(userId) || isSuperAdmin();
    }

    match /system/appConfig {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin();
    }
  }
}
